# Database (PostgreSQL local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tatuzinho_dev
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600

# FastAPI
DEBUG=True
ENV=development
LOG_LEVEL=INFO

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Scraping
SCRAPER_ENABLED=True
BACKFILL_ENABLED=False
BACKFILL_YEARS=2

# Predictions
PREDICTION_MODEL_PATH=/tmp/prediction_model.pkl
MIN_HISTORICAL_MATCHES=5
