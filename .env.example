# Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ljctyleqgpecezgtulhf.supabase.co:5432/postgres
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600

# FastAPI
DEBUG=True
ENV=development
LOG_LEVEL=INFO

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Scraping
SCRAPER_ENABLED=True
