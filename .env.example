# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tatuzinho_db
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600

# FastAPI
DEBUG=True
ENV=development
LOG_LEVEL=INFO

# SofaScore API
SOFASCORE_API_BASE_URL=https://api.sofascore.com/api/v1
SOFASCORE_RATE_LIMIT_DELAY=1.0
SOFASCORE_BATCH_SIZE=50
SOFASCORE_MAX_RETRIES=3
SOFASCORE_TIMEOUT=30

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Scraping
SCRAPER_ENABLED=True
BACKFILL_ENABLED=False
BACKFILL_YEARS=2

# Predictions
PREDICTION_MODEL_PATH=/tmp/prediction_model.pkl
MIN_HISTORICAL_MATCHES=5
